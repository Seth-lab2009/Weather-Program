#include <iostream>
#include <cmath>
using namespace std;

// Functions are declared here
void runWeatherProgram();
double calculateWindChill(double tempF, double windMph);
double calculateCloudBase(double tempF, double dewPointF);

int main() {
    cout << "Weather Calculator\n";
    runWeatherProgram();  // The 
    return 0;
}

//  Input, function calls, and output
void runWeatherProgram() {
    double tempF, windMph, dewPointF;

    cout << "Enter temperature (°F): ";
    cin >> tempF;

    cout << "Enter wind speed (mph): ";
    cin >> windMph;

    cout << "Enter dew point (°F): ";
    cin >> dewPointF;

    double windChill = calculateWindChill(tempF, windMph);
    double cloudBase = calculateCloudBase(tempF, dewPointF);

    if (tempF <= 50 && windMph >= 3) {
        cout << "\nWind Chill: " << windChill << " °F" << endl;
    } else {
        cout << "\nWind Chill not valid for these conditions." << endl;
    }

    cout << "Cloud Base: " << cloudBase << " feet" << endl;
}

// Wind chill function
double calculateWindChill(double tempF, double windMph) {
    return 35.74 + (0.6215 * tempF)
         - (35.75 * pow(windMph, 0.16))
         + (0.4275 * tempF * pow(windMph, 0.16));
}

