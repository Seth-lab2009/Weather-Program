// Wind chill calculation
void calcWindChill(double tempF, double windMph, double &windChill) {
	if (windMph < 3) {
		windChill = tempF;
		return;
	}

	windChill = 35.74
	            + (0.6215 * tempF)
	            - (35.75 * pow(windMph, 0.16))
	            + (0.4275 * tempF * pow(windMph, 0.16));
}

// Cloud base calculation
void calcCloudBase(double tempF, double dewPoint, double &cloudBase) {
	if (dewPoint > tempF) {
		cloudBase = 0;
		return;
	}

	cloudBase = (tempF - dewPoint) * 222;
}
