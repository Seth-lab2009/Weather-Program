#include <iostream>
#include <cmath>
using namespace std;

// Function prototypes
void runProgram();
double calculateWindChill(double tempF, double windMph);
double calculateCloudBase(double tempF, double dewPointF);

int main() {
    cout << "Weather Calculator\n";
    runProgram();  // everything else happens here
    return 0;
}

// Handles input, function calls, and output
void runProgram() {
    double temp, wind, dewPoint;

    cout << "Enter temperature (°F): ";
    cin >> temp;

    cout << "Enter wind speed (mph): ";
    cin >> wind;

    cout << "Enter dew point (°F): ";
    cin >> dewPoint;

    double windChill = calculateWindChill(temp, wind);
    double cloudBase = calculateCloudBase(temp, dewPoint);

    if (temp <= 50 && wind >= 3) {
        cout << "\nWind Chill: " << windChill << " °F" << endl;
    } else {
        cout << "\nWind Chill not valid for these conditions." << endl;
    }

    cout << "Cloud Base: " << cloudBase << " feet" << endl;
}

// Wind chill function
double calculateWindChill(double tempF, double windMph) {
    return 35.74 + (0.6215 * tempF)
         - (35.75 * pow(windMph, 0.16))
         + (0.4275 * tempF * pow(windMph, 0.16));
}

// Cloud base function
double calculateCloudBase(double tempF, double dewPointF) {
    return (tempF - dewPointF) * 222;
}
